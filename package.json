{
    "name": "@sagifire/ioc-workspace",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.7.0",
    "scripts": {
        "build": "pnpm -r build",
        "clean": "pnpm -r --if-present clean",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "lint": "eslint .",
        "test": "pnpm build && vitest run",
        "test:unit": "vitest run",
        "typecheck": "tsc -b --pretty false && tsc -p tsconfig.test.json --pretty false"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@sagifire/ioc": "workspace:*",
        "@sagifire/ioc-next": "workspace:*",
        "@sagifire/ioc-testing": "workspace:*",
        "eslint": "^9.39.2",
        "prettier": "^3.7.4",
        "rimraf": "^6.1.2",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.50.0",
        "vitest": "^4.0.16"
    }
}
