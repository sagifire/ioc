{
    "name": "@sagifire/ioc",
    "version": "0.0.3",
    "description": "TypeScript-native IoC container, module composer, diagnostics and optional DSL.",
    "type": "module",
    "sideEffects": false,
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sagifire/ioc.git",
        "directory": "packages/ioc"
    },
    "homepage": "https://github.com/sagifire/ioc/tree/main/packages/ioc#readme",
    "bugs": {
        "url": "https://github.com/sagifire/ioc/issues"
    },
    "keywords": [
        "ioc",
        "dependency-injection",
        "dependency-composition",
        "typescript",
        "esm",
        "tokens",
        "container",
        "modules",
        "diagnostics"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./tokens": {
            "types": "./dist/tokens.d.ts",
            "import": "./dist/tokens.js"
        },
        "./container": {
            "types": "./dist/container.d.ts",
            "import": "./dist/container.js"
        },
        "./context": {
            "types": "./dist/context.d.ts",
            "import": "./dist/context.js"
        },
        "./composer": {
            "types": "./dist/composer.d.ts",
            "import": "./dist/composer.js"
        },
        "./dsl": {
            "types": "./dist/dsl.d.ts",
            "import": "./dist/dsl.js"
        },
        "./diagnostics": {
            "types": "./dist/diagnostics.d.ts",
            "import": "./dist/diagnostics.js"
        },
        "./graph-export": {
            "types": "./dist/graph-export.d.ts",
            "import": "./dist/graph-export.js"
        },
        "./lifecycle": {
            "types": "./dist/lifecycle.d.ts",
            "import": "./dist/lifecycle.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/*.d.ts",
        "dist/index.js",
        "dist/index.js.map",
        "dist/index.d.ts",
        "dist/tokens.js",
        "dist/tokens.js.map",
        "dist/tokens.d.ts",
        "dist/container.js",
        "dist/container.js.map",
        "dist/container.d.ts",
        "dist/context.js",
        "dist/context.js.map",
        "dist/context.d.ts",
        "dist/composer.js",
        "dist/composer.js.map",
        "dist/composer.d.ts",
        "dist/dsl.js",
        "dist/dsl.js.map",
        "dist/dsl.d.ts",
        "dist/diagnostics.js",
        "dist/diagnostics.js.map",
        "dist/diagnostics.d.ts",
        "dist/graph-export.js",
        "dist/graph-export.js.map",
        "dist/graph-export.d.ts",
        "dist/lifecycle.js",
        "dist/lifecycle.js.map",
        "dist/lifecycle.d.ts",
        "CHANGELOG.md",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "scripts": {
        "build": "tsup",
        "clean": "rimraf dist",
        "lint": "eslint .",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
