{
    "name": "@sagifire/ioc-next",
    "version": "0.0.1",
    "description": "Next.js App Router boundary helpers for explicit @sagifire/ioc scopes.",
    "type": "module",
    "sideEffects": false,
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sagifire/ioc.git",
        "directory": "packages/ioc-next"
    },
    "homepage": "https://github.com/sagifire/ioc/tree/main/packages/ioc-next#readme",
    "bugs": {
        "url": "https://github.com/sagifire/ioc/issues"
    },
    "keywords": [
        "ioc",
        "dependency-injection",
        "dependency-composition",
        "typescript",
        "esm",
        "nextjs",
        "app-router",
        "request-scope",
        "server-actions"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/index.js",
        "dist/index.js.map",
        "dist/index.d.ts",
        "CHANGELOG.md",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "dependencies": {
        "@sagifire/ioc": "workspace:*"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rimraf dist",
        "lint": "eslint .",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
