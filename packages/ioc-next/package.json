{
    "name": "@sagifire/ioc-next",
    "version": "0.0.0",
    "type": "module",
    "sideEffects": false,
    "license": "Apache-2.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "dependencies": {
        "@sagifire/ioc": "workspace:*"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rimraf dist",
        "lint": "eslint .",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
